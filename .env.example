# Database
DATABASE_URL="mysql://user:password@localhost:3306/kirana_saas"

# Auth
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# AI Forecasting — Gemini (used today by services/ai-forecast-service.ts).
# Get a key at https://aistudio.google.com/apikey. If unset, forecasting
# transparently falls back to the naive heuristic in forecast-service.ts.
LLM_API_KEY=""
LLM_MODEL="gemini-2.5-flash"

# Future Python AI Forecasting Service (FastAPI + Prophet + XGBoost) — an
# alternative/additional forecasting backend; not required for Gemini to work.
AI_SERVICE_URL="http://localhost:8000"
AI_SERVICE_API_KEY="change-me"

# Redis (future - AI service caching / job queue)
REDIS_URL="redis://localhost:6379"

# OpenAI (future - AI Chat Assistant; separate from LLM_API_KEY above)
OPENAI_API_KEY=""

# Email (password reset)
RESEND_API_KEY=""
EMAIL_FROM="Kirana AI <no-reply@kirana-ai.app>"
